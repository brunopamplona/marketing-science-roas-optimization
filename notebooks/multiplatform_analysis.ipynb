Célula 2: Carregamento de Dados

Python
# Carregando os datasets
df_camp = pd.read_csv('../data/campanhas_multiplatforma.csv')
df_crea = pd.read_csv('../data/analise_criativos.csv')

print(f"Dados carregados: {len(df_camp)} campanhas e {len(df_crea)} criativos.")

Célula 3: Execução do Modelo Prescritivo

Python
# Inicializa o motor
engine = PrescriptiveEngine(df_camp, df_crea)

# Aplica as ações de Stop/Start/Continue
df_camp_final, df_crea_final = engine.apply_stop_start_continue()

# Exibe o resumo para o CMO
summary = engine.get_cmo_summary(df_camp_final, df_crea_final)
print("--- SUMÁRIO EXECUTIVO PARA O CMO ---")
for key, val in summary.items():
    print(f"\n{key}:")
    for action, count in val.items():
        print(f" - {action}: {count}")

Célula 4: Análise de DNA Criativo (Feature Importance)

Python
# O que realmente causa o ROAS alto?
importance = engine.get_feature_importance()
print(importance)

# Visualização de ROAS por Estilo de Headline
plt.figure(figsize=(12,6))
sns.barplot(data=df_crea_final, x='Estilo_Headline', y='ROAS', hue='creative_action')
plt.title('Impacto do Estilo de Headline no ROAS e Ação Prescrita')
plt.xticks(rotation=45)
plt.savefig('../outputs/charts/headline_impact_roas.png')
plt.show()


