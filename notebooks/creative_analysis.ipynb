import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler
import statsmodels.api as sm

# 1. Setup e Carregamento
sns.set_theme(style="whitegrid")
df_crea = pd.read_csv('../data/analise_criativos.csv')

# --- ANÁLISE 1: O FUNIL DO CRIATIVO (HOOK VS HOLD) ---
# O objetivo aqui é ver onde perdemos o usuário.

plt.figure(figsize=(12, 6))
sns.scatterplot(data=df_crea, x='Hook_Rate_Pct', y='Hold_Rate_Pct', 
                hue='Estilo_Headline', size='ROAS', sizes=(20, 200), alpha=0.7)
plt.axvline(df_crea['Hook_Rate_Pct'].median(), color='red', linestyle='--', label='Mediana Hook')
plt.axhline(df_crea['Hold_Rate_Pct'].median(), color='blue', linestyle='--', label='Mediana Hold')
plt.title('Matriz de Performance Criativa: Hook Rate vs Hold Rate')
plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')
plt.show()

# --- ANÁLISE 2: CLUSTERIZAÇÃO DE CRIATIVOS (IA) ---
# Vamos agrupar criativos para entender os "perfis" de performance.

features_clustering = ['Hook_Rate_Pct', 'Hold_Rate_Pct', 'ROAS', 'Fatigue_Score']
scaler = StandardScaler()
X_scaled = scaler.fit_transform(df_crea[features_clustering].fillna(0))

kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
df_crea['Cluster'] = kmeans.fit_predict(X_scaled)

# Mapeando os nomes dos clusters baseado nas médias

cluster_map = {0: 'Vencedores Estáveis', 1: 'Clickbaits (Baixa Retenção)', 2: 'Baixa Performance/Fadiga'}
df_crea['Cluster_Name'] = df_crea['Cluster'].map(cluster_map)

plt.figure(figsize=(10, 5))
sns.boxplot(x='Cluster_Name', y='ROAS', data=df_crea)
plt.title('Distribuição de ROAS por Cluster de Criativo')
plt.show()

# --- ANÁLISE 3: DNA VISUAL (FEATURE IMPORTANCE) ---

# O que realmente importa: Rosto? Humor? Azul ou Vermelho?
features_dna = ['Estilo_Headline', 'Paleta_Cores', 'Presenca_Pessoa', 'Tipo_Criativo']
df_model = pd.get_dummies(df_crea[features_dna], drop_first=True)

X = sm.add_constant(df_model.astype(float))
y = df_crea['ROAS']
model = sm.OLS(y, X).fit()

# Plotando os coeficientes que mais impactam o ROAS

coef_df = model.params.sort_values().to_frame('Effect_on_ROAS').drop('const')
coef_df.plot(kind='barh', figsize=(10, 8), color='teal')
plt.title('DNA do Sucesso: Atributos que MAIS impactam o ROAS')
plt.xlabel('Coeficiente de Impacto no ROAS')
plt.show()

# --- ANÁLISE 4: DIAGNÓSTICO DE FADIGA ---

plt.figure(figsize=(10, 6))
sns.regplot(data=df_crea, x='Fatigue_Score', y='ROAS', scatter_kws={'alpha':0.5}, line_kws={'color':'red'})
plt.title('Correlação: Fadiga do Criativo vs ROAS')
plt.show()

# --- OUTPUT FINAL: O "BRIEF" PARA O TIME DE DESIGN ---
print("\n--- 💡 CREATIVE BRIEF BASEADO EM DADOS ---")

best_headline = df_crea.groupby('Estilo_Headline')['ROAS'].mean().idxmax()
best_palette = df_crea.groupby('Paleta_Cores')['ROAS'].mean().idxmax()
best_type = df_crea.groupby('Tipo_Criativo')['ROAS'].mean().idxmax()

print(f"1. Focar em Vídeos do tipo: {best_type}")
print(f"2. Utilizar Headline no estilo: {best_headline}")
print(f"3. Paleta de cores dominante: {best_palette}")
print(f"4. Alerta: Pausar imediatamente {len(df_crea[df_crea['Fatigue_Score'] > 60])} criativos por fadiga alta.")
